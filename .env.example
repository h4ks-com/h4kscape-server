# =============================================================================
# h4kscape-server — Environment Configuration
# Copy to .env and adjust values for your deployment.
# =============================================================================

# ── Web Server ───────────────────────────────────────────────
WEB_PORT=80
# WEB_ALLOWED_ORIGIN=           # Lock WebSocket to a specific origin

# ── Game Server ──────────────────────────────────────────────
NODE_PORT=43594
NODE_ID=10
NODE_MEMBERS=true
NODE_AUTO_SUBSCRIBE_MEMBERS=true
NODE_XPRATE=1
NODE_PRODUCTION=false
NODE_DEBUG=true
NODE_CLIENT_ROUTEFINDER=true
NODE_SOCKET_TIMEOUT=true

# ── Database ─────────────────────────────────────────────────
DB_BACKEND=sqlite

# ── Build / Cache ────────────────────────────────────────────
BUILD_STARTUP=true
BUILD_STARTUP_UPDATE=true
BUILD_VERIFY=false
BUILD_VERIFY_FOLDER=false
BUILD_VERIFY_PACK=false

# ── Sub-servers (disabled for single-world) ──────────────────
LOGIN_SERVER=false
FRIEND_SERVER=false
LOGGER_SERVER=false
WEBSITE_REGISTRATION=false

# ── Admin ────────────────────────────────────────────────────
HEAD_ADMIN=valware

# ── OAuth (Logto) ────────────────────────────────────────────
OAUTH_ENABLED=true
OAUTH_LOGTO_ENDPOINT=https://auth.h4ks.com
OAUTH_LOGTO_APP_ID=bc40c9vfeg5i43m9j8bws
OAUTH_CALLBACK_URL=https://scape.h4ks.com/auth/callback

# ── Client Origin (CORS for cross-domain client) ────────────
# Set this to the URL where the web client is hosted.
# Leave empty to disable CORS headers (same-origin deployment).
CLIENT_ORIGIN=https://scape.h4ks.com
